[
  {
    "id": "opencode",
    "label": "OpenCode AI",
    "mountPath": "/root/.config/opencode",
    "binaryUrl": "https://registry.npmjs.org/opencode-linux-x64-musl/-/opencode-linux-x64-musl-1.4.3.tgz",
    "binaryName": "opencode",
    "extraEnv": ["XDG_DATA_HOME=/tmp"],
    "tools": [
      {
        "name": "opencode-ai",
        "url": "https://opencode.ai/install",
        "installCmd": "bun install -g opencode-ai"
      }
    ]
  },
  {
    "id": "claude",
    "label": "Claude Code",
    "mountPath": "/root/.config/claude",
    "tools": [
      {
        "name": "@anthropic-ai/claude-code",
        "url": "https://www.npmjs.com/package/@anthropic-ai/claude-code",
        "installCmd": "npm install -g @anthropic-ai/claude-code"
      }
    ]
  },
  {
    "id": "kilo",
    "label": "Kilo Code",
    "mountPath": "/root/.config/kilo",
    "tools": [
      {
        "name": "@kilocode/cli",
        "url": "https://www.npmjs.com/package/@kilocode/cli",
        "installCmd": "npm install -g @kilocode/cli"
      }
    ]
  },
  {
    "id": "codex",
    "label": "Codex",
    "mountPath": "/root/.config/codex",
    "tools": [
      {
        "name": "@openai/codex",
        "url": "https://www.npmjs.com/package/@openai/codex",
        "installCmd": "npm install -g @openai/codex"
      }
    ]
  }
]
